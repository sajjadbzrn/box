import { Box, cors } from "boxfw-core";
{{#if hasLogger}}
import { createLogger, requestLogger } from "boxfw-logger";
{{/if}}
{{#if hasI18n}}
import { localeDetect, rtlMeta } from "boxfw-i18n";
{{/if}}
{{#if hasValidator}}
import { v, z } from "boxfw-validator";
{{/if}}
{{#if hasOpenapi}}
import { openapi, type RouteSpec } from "boxfw-openapi";
{{/if}}
{{#if hasDrizzle}}
import { D, typedDb, db } from "./db";
import * as schema from "../drizzle/schema";
{{/if}}
{{#if hasAuth}}
import { jwt } from "boxfw-auth";
import { registerAuthRoutes } from "./auth/routes";
{{/if}}

const app = new Box();

{{#if hasLogger}}
const log = createLogger({ level: "debug", name: "{{projectName}}" });
app.use(requestLogger({ logger: log }));
{{/if}}

app.use(cors({ origin: "*" }));

{{#if hasI18n}}
app.use(localeDetect({
  default: "en",
  supported: ["en", "fa"],
}));
{{/if}}

{{#if hasDrizzle}}
app.use(D(db));
{{/if}}

{{#if hasAuth}}
app.use(jwt({
  secret: process.env.JWT_SECRET || "dev-secret-change-me",
  optional: true,
}));
{{/if}}

{{#if hasOpenapi}}
const apiRoutes: RouteSpec[] = [
  {
    method: "GET",
    path: "/",
    summary: "Welcome message",
    tags: ["System"],
  },
  {
    method: "GET",
    path: "/health",
    summary: "Health check",
    tags: ["System"],
  },
];

app.get("/openapi.json", openapi(
  {
    title: "{{projectName}}",
    version: "0.0.0",
    description: "{{projectName}} API",
  },
  apiRoutes,
));
{{/if}}

app.notFound((c) => {
  return c.json({ error: "Not Found" }, 404);
});

app.onError((err, c) => {
  {{#if hasLogger}}
  log.error("Unhandled error", { error: err.message });
  {{else}}
  console.error(err);
  {{/if}}
  return c.json({ error: "Internal Server Error" }, 500);
});

// Health check
app.get("/health", (c) => {
  return c.json({ status: "ok", uptime: process.uptime() });
});

// Routes
app.get("/", (c) => {
  return c.json({
    message: "Hello, Box!",
    project: "{{projectName}}",
    runtime: "{{runtime}}",
    {{#if hasI18n}}
    locale: c.locale,
    dir: rtlMeta(c.locale).dir,
    {{/if}}
  });
});

{{#if hasValidator}}
// Zod validation example
const helloQuery = z.object({
  name: z.string().optional().default("World"),
});

app.get("/hello", v({ query: helloQuery }, (c) => {
  return c.json({ message: `Hello, ${c.validated.query.name}!` });
}));
{{/if}}

{{#if hasDrizzle}}
// Drizzle CRUD example
app.get("/users", async (c) => {
  const users = await typedDb(c).select().from(schema.users);
  return c.json(users);
});
{{/if}}

{{#if hasAuth}}
// Auth routes
registerAuthRoutes(app);
{{/if}}

{{#if isBunRuntime}}
const port = process.env.PORT ? Number(process.env.PORT) : 3000;
app.listen({ port });
{{#if hasLogger}}
log.info(`Server running at http://localhost:${port}`);
{{else}}
console.log(`Server running at http://localhost:${port}`);
{{/if}}
{{/if}}

export { app };
