{
  "name": "boxfw-validator",
  "version": "0.1.2",
  "description": "Box Framework — Zod-based request validation with full TypeScript type inference",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc --project tsconfig.json"
  },
  "author": "Box Framework Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sajjadbzrn/box.git"
  },
  "keywords": ["bun", "zod", "validation", "type-inference", "schema", "typescript"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "boxfw-core": "^0.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "bun-types": "latest"
